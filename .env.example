# Onelight configuration. Copy to .env and adjust.
# Note: docker-compose refuses to start unless SECRET_KEY and WORKER_SECRET
# are set (no insecure defaults).

# Public origin users reach the app at. Drives absolute URLs and the
# COOKIE_SECURE default (https implies secure cookies).
PUBLIC_URL=http://localhost:3000

# Listen address for the API server.
PORT=3000
HOST=0.0.0.0

# SQLite database file. Use an absolute path in production; relative paths
# resolve against the process working directory and move when it does.
# In docker this must live on the volume shared with the worker.
DATABASE_PATH=/data/onelight.db

# Blob storage root for originals, renditions, and exports. Defaults to a
# "blobs" directory next to DATABASE_PATH when unset. DATABASE_PATH and
# BLOB_ROOT must resolve to the same filesystem the worker mounts, or the
# worker cannot read sources and write renditions.
BLOB_ROOT=/data/blobs

# Session and signing key. At least 32 random characters. Required.
SECRET_KEY=replace-this-with-at-least-32-random-characters

# Force the secure flag on session cookies. Defaults to true when
# PUBLIC_URL is https, false otherwise.
COOKIE_SECURE=false

# Set to true when running behind a reverse proxy (Caddy, nginx) so
# client IPs are taken from X-Forwarded-For.
TRUST_PROXY=false
# Extra origins the CSRF check accepts, comma separated. PUBLIC_URL's own
# origin is always allowed and does not belong here.
#
# Cookie-carried mutations (login included) are rejected unless the request's
# Origin matches, so reaching a deployment by any name PUBLIC_URL does not
# name -- the LAN address while public DNS is still pending, a tailnet host,
# a second domain -- fails with "The request origin is not allowed." and looks
# like a broken login rather than a configuration problem.
#
# This widens the CSRF rule and nothing else: list exact origins you trust,
# never a wildcard. An unparseable entry fails at startup, not at request time.
#ONELIGHT_ALLOWED_ORIGINS=http://192.168.1.52:3000,https://review.internal.example.com

# Headless first-run admin. When both are set and the database has no
# users, this admin account and workspace are created at startup.
# The password is never printed; minimum 10 characters.
#ONELIGHT_ADMIN_EMAIL=admin@example.com
#ONELIGHT_ADMIN_PASSWORD=change-me-please
ONELIGHT_WORKSPACE_NAME=Onelight

# OIDC single sign-on. ISSUER, CLIENT_ID, and CLIENT_SECRET must be set
# together. AUTO_PROVISION creates users on first login; ALLOWED_DOMAINS
# is a comma-separated list of email domains permitted to provision.
#OIDC_ISSUER=https://accounts.example.com
#OIDC_CLIENT_ID=onelight
#OIDC_CLIENT_SECRET=replace-me
#OIDC_AUTO_PROVISION=false
#OIDC_ALLOWED_DOMAINS=example.com

# Media worker. Both must be set or media processing is disabled and
# probe/transcode jobs stay queued. WORKER_SECRET signs the job protocol
# in both directions.
WORKER_URL=http://localhost:8080
WORKER_SECRET=replace-this-with-a-worker-secret

# Ceiling for one worker job (probe or transcode) in milliseconds.
# Default 21600000 (6 hours). The pump heartbeats the job lease while it
# waits, so long encodes do not expire mid-run.
#WORKER_JOB_TIMEOUT_MS=21600000

# Hardware encoding for the media worker:
#   auto      probe usable backends, then fall back to libx264
#   vaapi     Intel Quick Sync, Intel Arc, or AMD on Linux
#   nvenc     NVIDIA on Linux, Docker, or Windows
#   amf       AMD on Windows
#   software  libx264
#
# Explicit GPU modes are strict. The worker performs a real one-frame encode
# before listening and refuses to start if the requested device, driver, or
# rate-control mode is unusable. Auto mode is the portable default.
ONELIGHT_HWACCEL=auto
#ONELIGHT_VAAPI_DEVICE=/dev/dri/renderD128
#ONELIGHT_VAAPI_LOW_POWER=true
#ONELIGHT_NVENC_DEVICE=0
#
# Docker users should use one GPU override:
#   deploy/docker-compose.gpu-intel.yml
#   deploy/docker-compose.gpu-nvidia.yml
#   deploy/docker-compose.gpu-amd.yml
# Intel and AMD render nodes also need the host render-group numeric GID:
#   ONELIGHT_RENDER_GID=109

# Maximum burned-watermark jobs enqueued per reconciliation sweep (the pump
# scans every 30 seconds for shares whose watermark spec lacks a rendition).
# Default 8.
#WATERMARK_SWEEP_LIMIT=8

# Outgoing email (notification emails, password resets). Email is disabled
# unless SMTP_URL or SMTP_HOST is set together with MAIL_FROM. SMTP_URL is
# a single connection string; the discrete SMTP_* settings are the
# alternative. SMTP_SECURE defaults to true on port 465, false otherwise.
#SMTP_URL=smtp://user:pass@mail.example.com:587
#SMTP_HOST=mail.example.com
#SMTP_PORT=587
#SMTP_USER=onelight
#SMTP_PASS=replace-me
#SMTP_SECURE=false
#MAIL_FROM=Onelight <onelight@example.com>

# Upload sessions whose current state has stayed stale for this long are
# reaped. Pending, uploading, quarantined and aborted sessions age from
# creation; completed sessions age from completion. Multipart state is
# aborted, part rows and the session are deleted, and partial blobs are
# removed. Milliseconds; default 604800000 (7 days).
#UPLOAD_REAP_AFTER_MS=604800000

# Soft-deleted assets and versions older than this are purged for good:
# blobs deleted, rows removed, one audit row per purge. Milliseconds;
# default 2592000000 (30 days).
#TRASH_PURGE_AFTER_MS=2592000000

# Blob GC reconciliation walks the local blob root and reports objects no
# database row references. It is a dry run (log only) unless
# ONELIGHT_GC_DELETE=true, and even then only orphans older than 24 hours
# are deleted. GC runs at most once per GC_INTERVAL_MS; default 86400000
# (24 hours).
#ONELIGHT_GC_DELETE=false
#GC_INTERVAL_MS=86400000
