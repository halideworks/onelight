{
  "name": "onelight",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @onelight/server dev",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -b packages/core packages/db packages/worker packages/player packages/api apps/server apps/cf apps/worker && tsc -p qa/tsconfig.json",
    "qa": "pnpm --filter @onelight/qa test",
    "qa:fixtures": "pnpm --filter @onelight/qa fixtures",
    "web:check": "pnpm --filter @onelight/web check",
    "openapi:gen": "tsx packages/api/src/generate-openapi.ts",
    "openapi:check": "tsx packages/api/src/generate-openapi.ts --check",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:check": "tsx packages/db/src/check-schema.ts",
    "seed": "tsx apps/server/src/seed.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.19",
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.0.5",
    "wrangler": "^4.5.0"
  }
}
